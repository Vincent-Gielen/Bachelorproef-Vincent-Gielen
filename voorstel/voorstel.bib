@InProceedings{PhillipsEtAl2013,
  author     = {Phillips, Brandon Kyle and Ryan, Sherry and Harden, Gina and Guynes, C. S. and Windsor, John},
  booktitle  = {Proceedings of the 2013 Annual Conference on Computers and People Research},
  date       = {2013-05},
  title      = {Motivating students to acquire mainframe skills},
  doi        = {10.1145/2487294.2487308},
  isbn       = {9781450319751},
  location   = {Cincinnati, Ohio, USA},
  pages      = {73--78},
  publisher  = {Association for Computing Machinery},
  series     = {SIGMIS-CPR '13},
  url        = {https://doi.org/10.1145/2487294.2487308},
  abstract   = {There has been a perception in both industry and in academia that mainframe skills are obsolete. As a result, there has been a decline in curricula addressing these skills. However, recent evidence shows that many organizations are still actively supporting mainframe technologies and report a need for students graduating in information technology to be trained in those skills, especially as much of their current mainframe workforce moves toward retirement. This paper examines the question of what motivates students to acquire mainframe skills. To do so, this research is investigates IBM's Master the Mainframe contest, a competition that attempts to engender enthusiasm for acquiring mainframe skills and ensure an adequate supply of such skills to organizations relying on them.},
  address    = {New York, NY, USA},
  collection = {SIGMIS-CPR ’13},
  keywords   = {motivation, mainframes, legacy systems},
  numpages   = {6},
}

